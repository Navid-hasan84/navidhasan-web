#!/usr/bin/env bash
set -Eeuo pipefail

COMMAND_NAME="$(basename "$0")"

SCRIPT_PATH="$(
  readlink -f "${BASH_SOURCE[0]}"
)"

PROJECT_ROOT="$(
  cd "$(dirname "$SCRIPT_PATH")/.."
  pwd
)"

STATE_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}/navidhasan-web-local"
RUN_DIR="$STATE_ROOT/run"
LOG_DIR="$STATE_ROOT/logs"

PID_FILE="$RUN_DIR/frontend.pid"
LOG_FILE="$LOG_DIR/frontend.log"

HOST="0.0.0.0"
PORT="3001"
LOCAL_URL="http://127.0.0.1:${PORT}"
BROWSER_URL="http://localhost:${PORT}"

mkdir -p "$RUN_DIR" "$LOG_DIR"

fail() {
  echo "FAIL: $*" >&2
  exit 1
}

process_start_time() {
  local pid="$1"
  local line
  local remainder

  IFS= read -r line < "/proc/$pid/stat" || return 1

  remainder="${line##*) }"
  set -- $remainder

  printf '%s\n' "${20}"
}

load_pid_record() {
  MANAGED_PID=""
  MANAGED_START_TIME=""

  test -r "$PID_FILE" || return 1

  read -r MANAGED_PID MANAGED_START_TIME < "$PID_FILE" || return 1

  [[ "$MANAGED_PID" =~ ^[0-9]+$ ]] || return 1
  [[ "$MANAGED_START_TIME" =~ ^[0-9]+$ ]] || return 1
}

managed_process_running() {
  local current_start_time

  load_pid_record || return 1

  kill -0 "$MANAGED_PID" 2>/dev/null || return 1

  current_start_time="$(
    process_start_time "$MANAGED_PID" 2>/dev/null || true
  )"

  test "$current_start_time" = "$MANAGED_START_TIME"
}

port_is_listening() {
  ss -ltnH |
    awk '{ print $4 }' |
    grep -Eq "[:.]${PORT}$"
}

wait_for_http() {
  local attempt

  for attempt in $(seq 1 100)
  do
    if curl \
      --fail \
      --silent \
      --show-error \
      --max-time 2 \
      --output /dev/null \
      "$LOCAL_URL" \
      2>/dev/null
    then
      return 0
    fi

    sleep 0.25
  done

  return 1
}

show_recent_log() {
  if test -f "$LOG_FILE"
  then
    tail -n 30 "$LOG_FILE"
  else
    echo "No development log exists yet."
  fi
}

run_site() {
  local pid
  local start_time=""

  test -f "$PROJECT_ROOT/package.json" ||
    fail "package.json was not found at $PROJECT_ROOT."

  if managed_process_running
  then
    echo "Navid Hasan Web is already running."
    echo "PID: $MANAGED_PID"
    echo "URL: $BROWSER_URL"
    echo "Log: $LOG_FILE"
    return 0
  fi

  if test -e "$PID_FILE"
  then
    rm -f "$PID_FILE"
  fi

  if port_is_listening
  then
    echo "Port $PORT is already occupied:"
    ss -ltnp 2>/dev/null |
      grep -E "[:.]${PORT}[[:space:]]" ||
      true

    fail "refusing to start on an occupied port."
  fi

  cd "$PROJECT_ROOT"

  if test ! -d node_modules
  then
    echo "Dependencies are not installed."
    echo "Running npm ci..."
    npm ci
  fi

  : > "$LOG_FILE"

  echo "Starting Navid Hasan Web in development mode..."

  (
    cd "$PROJECT_ROOT"

    exec nohup \
      setsid \
      npm run dev -- \
        --hostname "$HOST" \
        --port "$PORT"
  ) >> "$LOG_FILE" 2>&1 < /dev/null &

  pid="$!"

  for _ in $(seq 1 20)
  do
    if kill -0 "$pid" 2>/dev/null
    then
      start_time="$(
        process_start_time "$pid" 2>/dev/null || true
      )"

      if test -n "$start_time"
      then
        break
      fi
    fi

    sleep 0.05
  done

  if test -z "$start_time"
  then
    echo
    show_recent_log
    fail "development server exited during startup."
  fi

  printf '%s %s\n' "$pid" "$start_time" > "$PID_FILE"

  if ! wait_for_http
  then
    echo
    show_recent_log

    if kill -0 "$pid" 2>/dev/null
    then
      kill -TERM -- "-$pid" 2>/dev/null || true
    fi

    rm -f "$PID_FILE"

    fail "development server did not become ready."
  fi

  echo
  echo "Navid Hasan Web started successfully."
  echo "PID: $pid"
  echo "URL: $BROWSER_URL"
  echo "Log: $LOG_FILE"
}

show_status() {
  echo "=== NAVID HASAN WEB LOCAL STATUS ==="
  echo

  if managed_process_running
  then
    echo "Application: running"
    echo "PID:         $MANAGED_PID"
    echo "URL:         $BROWSER_URL"
  else
    echo "Application: stopped"

    if test -e "$PID_FILE"
    then
      echo "PID record:  stale"
    else
      echo "PID record:  absent"
    fi
  fi

  echo
  echo "Port $PORT:"

  if port_is_listening
  then
    ss -ltnp 2>/dev/null |
      grep -E "[:.]${PORT}[[:space:]]" ||
      echo "Listening, but process details are unavailable."
  else
    echo "Free"
  fi

  echo
  echo "HTTP check:"

  if curl \
    --silent \
    --show-error \
    --max-time 5 \
    --output /dev/null \
    --write-out "HTTP %{http_code}\n" \
    "$LOCAL_URL" \
    2>/dev/null
  then
    :
  else
    echo "No response"
  fi

  echo
  echo "Recent log:"
  show_recent_log
}

stop_site() {
  local process_group

  if ! load_pid_record
  then
    rm -f "$PID_FILE"
    echo "Navid Hasan Web is already stopped."
    return 0
  fi

  if ! managed_process_running
  then
    rm -f "$PID_FILE"
    echo "Removed a stale Navid Hasan Web PID record."
    return 0
  fi

  process_group="$(
    ps -o pgid= -p "$MANAGED_PID" |
      tr -d ' '
  )"

  if test "$process_group" != "$MANAGED_PID"
  then
    fail \
      "PID $MANAGED_PID is not the expected process-group leader; refusing to stop it."
  fi

  echo "Stopping Navid Hasan Web..."
  echo "PID: $MANAGED_PID"

  kill -TERM -- "-$process_group"

  for _ in $(seq 1 40)
  do
    if ! kill -0 -- "-$process_group" 2>/dev/null
    then
      rm -f "$PID_FILE"
      echo "Navid Hasan Web stopped successfully."
      return 0
    fi

    sleep 0.25
  done

  echo "The process did not stop gracefully."
  echo "Terminating its managed process group."

  kill -KILL -- "-$process_group" 2>/dev/null || true

  rm -f "$PID_FILE"

  echo "Navid Hasan Web stopped."
}

case "$COMMAND_NAME" in
  run_navidhasan-web)
    run_site
    ;;

  status_navidhasan-web)
    show_status
    ;;

  stop_navidhasan-web)
    stop_site
    ;;

  *)
    fail \
      "unsupported command name '$COMMAND_NAME'. Use run_navidhasan-web, status_navidhasan-web, or stop_navidhasan-web."
    ;;
esac
